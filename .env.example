# ============================================================
# Personal Knowledge Agent — Environment Variables
# Скопируй в .env и заполни своими значениями
# ============================================================

# PostgreSQL (Docker: порт 5434, локальный PG: твой порт)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/knowledge_agent

# Voyage AI — для эмбеддингов (рекомендован Anthropic для Claude)
# Регистрация и ключ: https://www.voyageai.com
# Бесплатно: 200M токенов на старте
VOYAGE_API_KEY=pa-....

# Notion — ОПЦИОНАЛЬНО. Синхронизация отключена с 13.06.2026 (KB самодостаточен).
# Эти переменные можно оставить пустыми — приложение работает без Notion.
# Создать интеграцию (если вернёшь синк): https://www.notion.so/my-integrations
NOTION_API_KEY=

# Корневые страницы для индексации (через запятую, Notion Page IDs)
NOTION_ROOT_PAGE_IDS=

# Авто-синхронизация Notion каждые 2 часа. По умолчанию ВЫКЛЮЧЕНА.
# Чтобы вернуть периодический синк — выставь true (и заполни NOTION_API_KEY выше).
NOTION_SYNC_ENABLED=false

# Параметры чанкинга (менять не нужно)
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_BATCH_SIZE=100

# Параметры поиска
DEFAULT_TOP_K=5
