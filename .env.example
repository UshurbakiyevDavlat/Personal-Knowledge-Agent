# ============================================================
# Personal Knowledge Agent — Environment Variables
# Скопируй в .env и заполни своими значениями
# ============================================================

# PostgreSQL (Docker: порт 5434, локальный PG: твой порт)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/knowledge_agent

# Voyage AI — для эмбеддингов (рекомендован Anthropic для Claude)
# Регистрация и ключ: https://www.voyageai.com
# Бесплатно: 200M токенов на старте
VOYAGE_API_KEY=pa-...

# Notion — для индексации страниц
# Создать интеграцию: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...

# Корневые страницы для индексации (через запятую, Notion Page IDs)
# ID берётся из URL страницы Notion
NOTION_ROOT_PAGE_IDS=32e26263-0981-8125-9e1c-d2a86e0d4915

# Параметры чанкинга (менять не нужно)
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_BATCH_SIZE=100

# Параметры поиска
DEFAULT_TOP_K=5
